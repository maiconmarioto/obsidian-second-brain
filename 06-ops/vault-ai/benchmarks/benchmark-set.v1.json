    },
    {
      "id": "q11-coziva-accepted-decisions",
      "phase_focus": [1, 2],
      "category": "filtered-decision-retrieval",
      "language": "pt-BR",
      "query": "Mostre decisoes aceitas do projeto Coziva.",
      "filters": {
        "type": "decision",
        "path_prefix": "01-projects/coziva/"
      },
      "expected_primary_hits": [
        {
          "path": "01-projects/coziva/decisions/0001-rebuild-contract.md",
          "heading": "# Decision: Coziva e um rebuild separado do legado",
          "rank_at_most": 1,
          "match_type": "frontmatter.status"
        }
      ],
      "expected_supporting_hits": [],
      "must_include_terms": ["accepted", "0001", "rebuild"],
      "rationale": "Decision filters should allow a clean project-scoped listing without bringing in shared or template decisions."

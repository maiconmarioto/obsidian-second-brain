    {
      "id": "q06-mmarioto-mailto-post-deploy",
      "phase_focus": [1, 2],
      "category": "risk-and-follow-up",
      "language": "pt-BR",
      "query": "Qual projeto ainda depende de mailto e o que falta validar depois do deploy?",
      "filters": {},
      "expected_primary_hits": [
        {
          "path": "01-projects/mmarioto-landingpage/context.md",
          "heading": "## Known limitations",
          "rank_at_most": 2,
          "match_type": "section"
        },
        {
          "path": "01-projects/mmarioto-landingpage/tasks.md",
          "heading": "## Next",
          "rank_at_most": 3,
          "match_type": "section"

    },
    {
      "id": "q08-agent-read-order-and-volatile-facts",
      "phase_focus": [1, 2],
      "category": "agent-protocol",
      "language": "pt-BR",
      "query": "Onde devo guardar fatos volateis e como um agente deve ler o vault antes de editar?",
      "filters": {},

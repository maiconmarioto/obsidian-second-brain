    {
      "id": "q05-mmarioto-release-baseline",
      "phase_focus": [1],
      "category": "release-baseline",
      "language": "pt-BR",
      "query": "Qual projeto esta na release 1.0.0 e qual o dominio de producao?",
      "filters": {},
      "expected_primary_hits": [
        {
          "path": "01-projects/mmarioto-landingpage/index.md",
          "heading": "# Project: mmarioto-landingpage",
          "rank_at_most": 2,

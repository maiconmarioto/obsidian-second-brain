    },
    {
      "id": "q09-research-recommendations-for-vault-search",
      "phase_focus": [1, 2, 3],
      "category": "research-synthesis",
      "language": "pt-BR",
      "query": "O que a pesquisa de 17 de abril de 2026 recomenda copiar para melhorar busca e memoria do vault?",
      "filters": {},
      "expected_primary_hits": [
        {
          "path": "06-ops/ai-vault-landscape-2026-04-17.md",
          "heading": "## What we should copy",
          "rank_at_most": 1,
          "match_type": "section"
        }
      ],
      "expected_supporting_hits": [
        {
          "path": "06-ops/ai-vault-landscape-2026-04-17.md",
          "heading": "## Recommended direction for this vault",
          "rank_at_most": 3,
          "match_type": "section"
        }
      ],
      "must_include_terms": ["hybrid retrieval", "fragments", "context packs", "core memory"],

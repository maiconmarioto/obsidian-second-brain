      "expected_primary_hits": [
        {
          "path": "01-projects/cookie-manager/index.md",
          "heading": "# Project: cookie-manager",
          "rank_at_most": 3,
          "match_type": "frontmatter.status"
        },
        {
          "path": "01-projects/coziva/index.md",
          "heading": "# Project: coziva",
          "rank_at_most": 3,
          "match_type": "frontmatter.status"
        },
        {
          "path": "01-projects/mmarioto-landingpage/index.md",
          "heading": "# Project: mmarioto-landingpage",

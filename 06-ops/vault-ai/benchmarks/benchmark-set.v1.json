{
  "version": "2026-04-17.v1",
  "name": "obsidian-second-brain-initial-benchmark-set",
  "description": "Initial retrieval benchmark set for the current vault state. Covers natural-language lookup, section ranking, alias expansion, bilingual recall, and metadata filters.",
  "defaults": {
    "target_top_k": 5,
    "matching_normalization": {
      "lowercase": true,
      "strip_accents": true
    },
    "pass_criteria": {
      "primary_hit_within_rank": 3,
      "supporting_hit_within_rank": 5,
      "must_include_terms_from_any_top_k_hit": true
    }
  },
  "queries": [
    {
      "id": "q01-cookie-manager-next-action",
      "phase_focus": [1],
      "category": "project-entrypoint",
      "language": "pt-BR",
      "query": "Qual e o proximo passo do projeto cookie-manager?",
      "filters": {},
      "expected_primary_hits": [
        {
          "path": "01-projects/cookie-manager/index.md",
          "heading": "# Project: cookie-manager",
          "rank_at_most": 1,
          "match_type": "frontmatter.next_action"
        }
      ],
      "expected_supporting_hits": [
        {
          "path": "01-projects/cookie-manager/tasks.md",
          "heading": "## Now",
          "rank_at_most": 3,
          "match_type": "section"
        }
      ],
      "must_include_terms": ["Prisma", "legado", "rebuild"],
      "rationale": "Project index frontmatter should answer the query directly, with the active task queue as supporting evidence."
    },
    {
      "id": "q02-cookie-manager-typecheck-breakage",
      "phase_focus": [1],
      "category": "operating-state",
      "language": "pt-BR",
      "query": "Qual projeto esta com typecheck quebrado por Prisma relations?",
      "filters": {},
      "expected_primary_hits": [
        {
          "path": "01-projects/cookie-manager/index.md",
          "heading": "## Current operating state",
          "rank_at_most": 2,
          "match_type": "section"
        }
      ],
      "expected_supporting_hits": [
        {
          "path": "01-projects/cookie-manager/tasks.md",
          "heading": "## Now",
          "rank_at_most": 3,
          "match_type": "section"
        }
      ],
      "must_include_terms": ["npx tsc --noEmit", "Prisma/relations", "receitas"],
      "rationale": "Section-level retrieval should prefer the exact operational-state section over broader project summaries."
    },
    {
      "id": "q03-coziva-rebuild-decision",
      "phase_focus": [1, 2],
      "category": "decision-retrieval",
      "language": "pt-BR",
      "query": "Coziva e continuacao do legado ou um rebuild separado?",
      "filters": {},
      "expected_primary_hits": [
        {
          "path": "01-projects/coziva/decisions/0001-rebuild-contract.md",
          "heading": "# Decision: Coziva e um rebuild separado do legado",
          "rank_at_most": 1,
          "match_type": "title"
        }
      ],
      "expected_supporting_hits": [
        {
          "path": "01-projects/coziva/index.md",
          "heading": "# Project: coziva",
          "rank_at_most": 3,
          "match_type": "title"
        }
      ],
      "must_include_terms": ["rebuild", "separado", "referencia funcional"],
      "rationale": "Accepted decision notes should outrank project summaries for explicit strategy questions."
    },
    {
      "id": "q04-coziva-target-stack",
      "phase_focus": [1],
      "category": "technical-shape",
      "language": "pt-BR",
      "query": "Qual e a stack alvo do Coziva?",
      "filters": {},
      "expected_primary_hits": [
        {
          "path": "01-projects/coziva/context.md",
          "heading": "## Technical shape",
          "rank_at_most": 1,
          "match_type": "section"
        }
      ],
      "expected_supporting_hits": [
        {
          "path": "01-projects/coziva/index.md",
          "heading": "# Project: coziva",
          "rank_at_most": 3,
          "match_type": "frontmatter.primary_stack"
        }
      ],
      "must_include_terms": ["Nx", "TanStack Start", "Fastify", "Trigger.dev"],
      "rationale": "Technical stack queries should prefer the context note section that concentrates durable architecture facts."
